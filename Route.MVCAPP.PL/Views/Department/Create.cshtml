@using Route.MVCAPP.BLL.DTOs.Departments
@* Part 8 Department Controller - Create *@
@model CreatedDepartmentDto

@{
    ViewData["Title"] = "Create";
}
<div class="row justify-content-center align-baselinealign-items-center">
	<h1>Create New Department</h1>
	<br />
	<br />

	<form asp-action="Create" class="col-8">
		<div asp-validation-summary="ModelOnly"></div>

	<div class="form-group mb-3">

<label class="col-form-label">Code</label>
		<input asp-for="Code" class="form-control" />
		<span asp-validation-for="Code" class="text-danger"></span>

	</div>

	<div class="form-group mb-3">
		<label class="col-form-label">Name</label>
		<input asp-for="Name" class="form-control" />
		<span asp-validation-for="Name" class="text-danger"></span>
	</div>

		<div class="form-group mb-3">
			<label class="col-form-label">Description</label>
			<textarea asp-for="Description" class="form-control"></textarea>
		</div>

		<div class="form-group mb-3">
			<label class="col-form-label">Creation Date</label>
			<input type="date" asp-for="CreationDate" class="form-control" />
			
		</div>

		<div class="mt-4">
			<input type="submit" value="Create" class="btn btn-primary" />
			<a asp-action="Index" class="btn btn-light">Back to List</a>
		</div>


	</form>
</div>
@* Part 3 Client-Side Validation *@
@section ValidationScripts {
	<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
	<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

}