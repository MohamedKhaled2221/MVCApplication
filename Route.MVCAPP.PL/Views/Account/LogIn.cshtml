@model LoginViewModel
@{
    ViewData["Title"] = "LogIn";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="main-agileinfo">
	<div class="agileits-top">
		<form asp-action="LogIn">
			<div asp-validation-summary="ModelOnly"></div>
		
			<br />

			<input class="text email" asp-for="Email" placeholder="Email" required="">
			<span asp-validation-for="Email" class="text-danger"></span>
			<br />
			<input class="text" asp-for="Password" placeholder="Password" required="">
			<span asp-validation-for="Password" class="text-danger"></span>
			<br />
			
			<div class="wthree-text">
				<label class="anim">
					<input type="checkbox" asp-for="RememberMe" class="checkbox" required="">
					<span>Remember Me</span>
				</label>
				<div class="clear"> </div>
			</div>
			<input type="submit" value="LogIn">
		</form>
		<p>Don't' have an Account? <a asp-action="Register"> SignUp Now!</a></p>
		<p>Forget Password ? <a asp-action="Forget Password"> Forget Password</a></p>
	</div>
</div>
@section ValidationScripts {

	<partial name="_ValidationScriptsPartial" />

}


